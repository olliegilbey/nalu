#!/usr/bin/env bash
#
# Pre-commit Hook for Nalu
# Fail-fast ordering: Secrets → Lint → Typecheck → Tests
#
# Philosophy: Catch agent and human mistakes before they hit the repo.
# AI agents are particularly prone to: leaking API keys into code,
# introducing type errors, and skipping tests. This hook catches all three.
#
# Fast path (no tests needed): ~5-10s
# Full path: ~15-25s
#
# Skip only in emergency: git commit --no-verify

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

START_TIME=$(date +%s)
PRECOMMIT_MAX_DURATION=60

echo ""
printf "${BLUE}🔒 Pre-commit: Fail-fast validation${NC}\n"
echo ""

# ============================================
# PHASE 1: SECRET SCANNING (~3-5s)
# Agents leak keys. Catch them before push.
# ============================================
printf "${BLUE}→ Phase 1/4: Secret scanning${NC}\n"

# 1.1 Gitleaks (uses .gitleaks.toml if present)
if command -v gitleaks &> /dev/null; then
  GITLEAKS_OUTPUT=$(gitleaks detect --no-banner --verbose --no-git 2>&1)
  if ! echo "$GITLEAKS_OUTPUT" | grep -q "no leaks found"; then
    printf "${RED}❌ Gitleaks found secrets!${NC}\n"
    echo "$GITLEAKS_OUTPUT"
    printf "${YELLOW}Fix: remove the secret, add to .gitleaks.toml allowlist if false positive.${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Gitleaks: clean\n"
else
  printf "${YELLOW}  ⚠ Gitleaks not installed (brew install gitleaks)${NC}\n"
fi

# 1.2 Ripsecrets (fast, regex-based)
if command -v ripsecrets &> /dev/null; then
  if ! ripsecrets --strict-ignore . 2>&1; then
    printf "${RED}❌ Ripsecrets found secrets!${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Ripsecrets: clean\n"
else
  printf "${YELLOW}  ⚠ Ripsecrets not installed (brew install ripsecrets)${NC}\n"
fi

# 1.3 Trufflehog (deep scan on staged files only — verified secrets)
if command -v trufflehog &> /dev/null; then
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
  if [ -n "$STAGED_FILES" ]; then
    TRUFFLEHOG_OUTPUT=$(echo "$STAGED_FILES" | xargs trufflehog filesystem --no-update --only-verified --json 2>&1 || true)
    if echo "$TRUFFLEHOG_OUTPUT" | grep -q '"DetectorType"'; then
      printf "${RED}❌ Trufflehog found verified secrets!${NC}\n"
      echo "$TRUFFLEHOG_OUTPUT" | grep '"DetectorType"'
      exit 1
    fi
    printf "${GREEN}  ✓${NC} Trufflehog: clean\n"
  fi
else
  printf "${YELLOW}  ⚠ Trufflehog not installed (brew install trufflehog)${NC}\n"
fi

printf "${GREEN}✅ Phase 1 complete: No secrets detected${NC}\n"
echo ""

# ============================================
# PHASE 1.5: AUTO-FORMAT STAGED (lint-staged)
# Prettier --write + eslint --fix on staged files only.
# Auto-fixes reformat-only drift; re-stages under the hood.
# ============================================
printf "${BLUE}→ Phase 1.5/4: Auto-format staged${NC}\n"
if ! bun x lint-staged 2>&1; then
  printf "${RED}❌ lint-staged failed${NC}\n"
  exit 1
fi
printf "${GREEN}✅ Phase 1.5 complete: staged files formatted${NC}\n"
echo ""

# ============================================
# PHASE 2: LINT (~3-5s, only staged TS files)
# Agents introduce lint violations frequently.
# ============================================
printf "${BLUE}→ Phase 2/4: Lint${NC}\n"

TS_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$TS_STAGED" ]; then
  if ! bun x eslint $TS_STAGED 2>&1; then
    printf "${RED}❌ ESLint failed${NC}\n"
    printf "${YELLOW}Run 'just lint' to see full output.${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} ESLint passed\n"
else
  printf "${GREEN}  ✓${NC} No TS/JS files staged (skipped)\n"
fi

printf "${GREEN}✅ Phase 2 complete: Lint passed${NC}\n"
echo ""

# ============================================
# PHASE 3: TYPECHECK (~5-10s, if TS files changed)
# Full project typecheck catches cascading type errors.
# ============================================
printf "${BLUE}→ Phase 3/4: Typecheck${NC}\n"

if [ -n "$TS_STAGED" ]; then
  if ! bun x tsc --noEmit 2>&1; then
    printf "${RED}❌ TypeScript typecheck failed${NC}\n"
    printf "${YELLOW}Run 'just typecheck' to see full output.${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} TypeScript typecheck passed\n"
else
  printf "${GREEN}  ✓${NC} No TS/JS files staged (skipped)\n"
fi

printf "${GREEN}✅ Phase 3 complete: Typecheck passed${NC}\n"
echo ""

# ============================================
# PHASE 4: TESTS (~5-10s, if TS files changed)
# Run the full test suite. Fast with vitest.
# ============================================
printf "${BLUE}→ Phase 4/4: Tests${NC}\n"

if [ -n "$TS_STAGED" ]; then
  if ! bun run test 2>&1; then
    printf "${RED}❌ Tests failed${NC}\n"
    printf "${YELLOW}Run 'just test' to see full output.${NC}\n"
    exit 1
  fi
  printf "${GREEN}  ✓${NC} Tests passed\n"
else
  printf "${GREEN}  ✓${NC} No TS/JS files staged (skipped)\n"
fi

printf "${GREEN}✅ Phase 4 complete: Tests passed${NC}\n"
echo ""

# ============================================
# TIMING
# ============================================
END_TIME=$(date +%s)
DURATION=$((END_TIME - START_TIME))

if (( DURATION > PRECOMMIT_MAX_DURATION )); then
  printf "${RED}❌ Pre-commit exceeded ${PRECOMMIT_MAX_DURATION}s (took ${DURATION}s)${NC}\n"
  printf "${YELLOW}Investigate what's slow. Emergency bypass: git commit --no-verify${NC}\n"
  exit 1
fi

printf "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
printf "${GREEN}✅ All pre-commit checks passed (${DURATION}s)${NC}\n"
printf "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
echo ""

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example

# Claude Code local overrides (personal, not committed)
CLAUDE.local.md
.claude/scheduled_tasks.lock
# ephemeral subagent worktrees created during parallel agent sessions
.claude/worktrees/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ai sdk devtools local capture (learner content + grading keys)
.devtools/

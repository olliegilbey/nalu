# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Provider (OpenAI-compatible)
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=your-cerebras-api-key
# llama3.1-8b is the floor model; deprecates 2026-05-27. Smoke tests swap to
# qwen-3-235b-a22b-instruct-2507 for the close-scoping turn only (8k ceiling
# overflows there). Capability flags live in src/lib/llm/modelCapabilities.ts.
LLM_MODEL=llama3.1-8b

# Dev mode (auto-login, skip auth)
NEXT_PUBLIC_DEV_MODE=false

# Postgres / Supabase
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Dev user UUID — used by seed.ts and tRPC procedures until auth lands
DEV_USER_ID=a0000000-0000-4000-8000-000000000001
